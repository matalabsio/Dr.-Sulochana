# Production site URL for canonical links, sitemap, and Open Graph
NEXT_PUBLIC_SITE_URL=https://www.drsulochanahospital.com

# Google Analytics (optional — tracks appointment form submissions)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity (optional — session recordings and heatmaps)
NEXT_PUBLIC_CLARITY_ID=

# WhatsApp number for appointment booking (country code, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=919849861089

# Google Sheets webhook — deploy scripts/google-sheets-webhook.gs as Apps Script web app
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Optional shared secret (must match Apps Script)
APPOINTMENTS_WEBHOOK_SECRET=your-secret-here
